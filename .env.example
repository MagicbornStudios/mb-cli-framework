# Optional: terminal chat (`magicborn chat`) calls your portfolio (or compatible) HTTP API.
# Server must expose POST /api/chat with the Site Copilot JSON contract (see README).

# Origin only; /api/chat is appended automatically.
MAGICBORN_CHAT_BASE_URL=http://127.0.0.1:3000

# Or set the full endpoint (wins over MAGICBORN_CHAT_BASE_URL):
# MAGICBORN_CHAT_URL=http://127.0.0.1:3000/api/chat

# Plain output / automation (no Ink home or chat TUI):
# MAGICBORN_PLAIN=1

# Headless Payload (host monorepo magicborn; optional):
# MAGICBORN_PAYLOAD_URL=http://127.0.0.1:3000
# MAGICBORN_PAYLOAD_USERS_API_KEY=
